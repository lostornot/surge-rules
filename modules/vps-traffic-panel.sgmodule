#!name=VPS 流量面板
#!desc=在 Surge 信息面板中显示多台 VPS 双向流量、剩余配额、使用率和重置倒计时。配置请使用 VPS_CONFIG_B64。
#!system=ios
#!arguments=VPS_CONFIG_B64=

[Panel]
VPS流量 = title="VPS 流量总览",content="请在 VPS_CONFIG_B64 中填写 VPS 配置",style=info,script-name=vps-traffic-panel,update-interval=3600

[Script]
vps-traffic-panel = type=generic,timeout=30,argument="VPS_CONFIG_B64=%VPS_CONFIG_B64%",script-path=https://raw.githubusercontent.com/lostornot/surge-rules/main/scripts/vps-traffic-panel.js
